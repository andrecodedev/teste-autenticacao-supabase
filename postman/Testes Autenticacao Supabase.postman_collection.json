{
  "info": {
    "_postman_id": "ade8fac3-3c55-4294-9122-9c48e9a76684",
    "name": "Testes Autenticacao Supabase",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "45104143"
  },
  "item": [
    {
      "name": "Login Válido",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "apikey",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"teste@email.com\",\n  \"password\": \"senhaerrada\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/auth/v1/token?grant_type=password",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "v1",
            "token"
          ],
          "query": [
            {
              "key": "grant_type",
              "value": "password"
            }
          ]
        }
      },
      "response": []
    }
  ]
}